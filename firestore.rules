rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Core validation primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validation helper: User
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt'])
        && data.keys().size() == 3
        && data.uid is string
        && data.uid.size() <= 128
        && data.email is string
        && data.email.size() <= 256
        && data.createdAt is timestamp;
    }

    // Entity validation helper: Favorite
    function isValidFavorite(data) {
      return data.keys().hasAll(['userId', 'type', 'externalId', 'title', 'createdAt'])
        && (data.keys().size() == 5 || (data.keys().size() == 6 && data.keys().hasAny(['snippet'])))
        && data.userId is string
        && data.userId.size() <= 128
        && data.type is string
        && (data.type == 'email' || data.type == 'file' || data.type == 'system')
        && data.externalId is string
        && data.externalId.size() <= 256
        && data.title is string
        && data.title.size() <= 512
        && (!data.keys().hasAny(['snippet']) || (data.snippet is string && data.snippet.size() <= 2048))
        && data.createdAt is timestamp;
    }

    // Entity validation helper: AuditLog
    function isValidAuditLog(data) {
      return data.keys().hasAll(['userId', 'action', 'createdAt'])
        && (data.keys().size() == 3 || (data.keys().size() == 4 && data.keys().hasAny(['details'])))
        && data.userId is string
        && data.userId.size() <= 128
        && data.action is string
        && data.action.size() <= 128
        && (!data.keys().hasAny(['details']) || (data.details is string && data.details.size() <= 4096))
        && data.createdAt is timestamp;
    }

    // User Resource Match Blocks
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == request.auth.uid && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == existing().uid && incoming().createdAt == existing().createdAt;

      // Subcollection: Favorites
      match /favorites/{favoriteId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) 
          && isValidId(favoriteId) 
          && isValidFavorite(incoming()) 
          && incoming().userId == request.auth.uid
          && incoming().createdAt == request.time;
        allow update: if isOwner(userId)
          && isValidFavorite(incoming())
          && incoming().userId == existing().userId
          && incoming().createdAt == existing().createdAt
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'snippet']);
        allow delete: if isOwner(userId);
      }

      // Subcollection: Audit Logs
      match /audit_logs/{logId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidId(logId)
          && isValidAuditLog(incoming())
          && incoming().userId == request.auth.uid
          && incoming().createdAt == request.time;
        
        // Audit logs are immutable once written
        allow update, delete: if false;
      }
    }
  }
}

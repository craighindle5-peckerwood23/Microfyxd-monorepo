# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""

# ==========================================
# CLOUD SQL / POSTGRESQL DATABASE CREDENTIALS
# ==========================================
# The hostname or IP address of the Cloud SQL instance
SQL_HOST=""
# The name of the database schema/database
SQL_DB_NAME=""

# Admin credentials used by Drizzle ORM migrations/schema push
SQL_ADMIN_USER=""
SQL_ADMIN_PASSWORD=""

# Application runtime credentials used to connect from the server
SQL_USER=""
SQL_PASSWORD=""

# ==========================================
# MICROFYXD CORE-T & STAGING INTEGRATIONS
# ==========================================
# Core-T configuration and Namecheap domain mapping
NAMECHEAP_DOMAIN="microfyxd.com"
NAMECHEAP_API_USER=""
NAMECHEAP_API_KEY=""

# Vercel deployment credentials for microfyxd-site
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""

# Secondary Core-T API Injections overrides (supports all 34 calls)
MICROFYXD_ECU_URL=""
MICROFYXD_ECU_SECRET=""
MICROFYXD_SANDBOX_VRAM_LIMIT=""
MICROFYXD_GPU_CLUSTER_IP=""
